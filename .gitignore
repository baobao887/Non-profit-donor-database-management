# Local database credentials — copy config/database.example.php to
# config/database.php on a new checkout. Never commit real credentials.
config/database.php

# Runtime error logs (see APP_ENV handling in config/constants.php)
logs/

# Tailwind standalone CLI binary (~40 MB) — download per README, never commit.
# The compiled assets/css/app.css IS committed and served directly.
tools/tailwindcss.exe
